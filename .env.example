# =============================================================================
# Grampanchayat — environment variables
# Copy this file to `.env.local` and fill in values from the Supabase dashboard.
# Never commit `.env.local` or paste the service role key in client-side code.
# =============================================================================

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose in the browser; used by lib/supabase.ts
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only (API routes via lib/supabase-server.ts). Keep secret.
# Do not use NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
